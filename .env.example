# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
# Full connection string (used by Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume_analyzer

# Individual fields (used by Docker Compose to init the container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=resume_analyzer

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a secure secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string-before-deploying
JWT_EXPIRES_IN=7d

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000

# ─── File Upload (Phase 2) ────────────────────────────────────────────────────
# Local directory for uploaded resume files (relative to project root)
UPLOAD_DIR=uploads
# Maximum upload size in MB
MAX_FILE_SIZE_MB=10

# ─── Embeddings (Phase 3) ────────────────────────────────────────────────────
# Required for semantic search. Without this, chunking still runs but search
# returns 503 ("embedding service not configured").
OPENAI_API_KEY=sk-...

# text-embedding-3-small: 1536 dims, $0.02/1M tokens (default, recommended)
# text-embedding-3-large: 3072 dims, higher quality, ~5x cost
# WARNING: changing the model after embeddings are stored requires a full
# re-embed of all chunks AND a Prisma migration to resize the vector column.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Maximum texts per OpenAI embedding API call (max: 2048)
EMBEDDING_BATCH_SIZE=100

# ─── Search (Phase 3) ────────────────────────────────────────────────────────
# Default number of results returned by POST /search
SEARCH_TOP_K=10
# Minimum cosine similarity (0–1) to include a result; tune to reduce noise
SEARCH_MIN_SIMILARITY=0.5

# ─── AI / LLM (Phase 5) ──────────────────────────────────────────────────────
# Primary AI provider: openai | gemini | groq
AI_PRIMARY_PROVIDER=openai

# Optional fallback provider if primary fails
# AI_FALLBACK_PROVIDER=groq

# OpenAI chat model (gpt-4o-mini is cost-effective and fast)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Google Gemini (alternative to OpenAI)
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash

# Groq (fast inference, OpenAI-compatible API)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# LLM request settings
AI_MAX_RETRIES=3
AI_RETRY_BASE_DELAY_MS=1000
AI_MAX_RESPONSE_TOKENS=1500
AI_CONTEXT_TOKEN_BUDGET=3000

# Response cache TTL in seconds (default: 6 hours)
AI_CACHE_TTL_SECONDS=21600

# ─── Redis / Queues (Phase 6) ────────────────────────────────────────────────
# When set, enables: Redis caching, BullMQ queues, async resume processing,
# Redis-backed rate limiting. When absent, server degrades gracefully.
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=3
REDIS_CONNECT_TIMEOUT=5000

# Cache TTL per entity type (seconds)
CACHE_TTL_RESUME=3600
CACHE_TTL_JOB=14400
CACHE_TTL_ANALYSIS=1800

# BullMQ worker concurrency (jobs processed simultaneously per worker instance)
QUEUE_CONCURRENCY=5

# How long to keep completed/failed job records in the queue (seconds)
QUEUE_REMOVE_ON_COMPLETE_AGE=86400
QUEUE_REMOVE_ON_FAIL_AGE=604800

# How long job status/result stays in Redis (seconds) — after this clients
# should use the main API to fetch the processed resource
JOB_STATUS_TTL=86400

# ─── Email / SMTP ────────────────────────────────────────────────────────────
#
# When SMTP_HOST + SMTP_USER + SMTP_PASS are all set, password-reset emails are
# sent to real inboxes via that SMTP provider.
#
# When these variables are absent, the server uses Ethereal — a fake inbox for
# local development. Emails are NOT delivered to real addresses in Ethereal mode.
# The Ethereal preview URL is returned in the API response and printed to the
# server console so you can inspect the email in a browser.
#
# APP_URL is required in production (used to build the reset link in the email).
#
# ── Gmail setup (recommended for development and small deployments) ──────────
#
#  Step 1 — Enable 2-Step Verification on the Google account:
#            https://myaccount.google.com/signinoptions/two-step-verification
#            (App Passwords are only available after 2SV is enabled.)
#
#  Step 2 — Create an App Password:
#            https://myaccount.google.com/apppasswords
#            App name: "Resumora" (or any label you choose)
#            Google generates a 16-character password like: abcd efgh ijkl mnop
#            Copy it — Google shows it only once.
#
#  Step 3 — Fill in the variables below:
#            SMTP_HOST = smtp.gmail.com
#            SMTP_PORT = 587          ← STARTTLS (preferred)
#            SMTP_USER = you@gmail.com
#            SMTP_PASS = abcdefghijklmnop   ← App Password without spaces
#            SMTP_FROM = "Resumora" <you@gmail.com>
#                        ↑ must match SMTP_USER for Gmail to accept the message
#            APP_URL   = http://localhost:3001   (or your production URL)
#
#  Step 4 — Restart the backend. The server logs "SMTP connection verified" if
#            the credentials are correct.
#
# ── Other providers ──────────────────────────────────────────────────────────
#
#  Mailgun:   SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
#  SendGrid:  SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587  SMTP_USER=apikey
#  Resend:    SMTP_HOST=smtp.resend.com   SMTP_PORT=465  SMTP_USER=resend
#             (Resend uses your API key as SMTP_PASS)
#  Mailtrap:  SMTP_HOST=sandbox.smtp.mailtrap.io  (staging/testing only)

APP_URL=http://localhost:3001

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=abcdefghijklmnop
SMTP_FROM="Resumora" <you@gmail.com>

# ─── Rate Limiting (Phase 6) ─────────────────────────────────────────────────
# Auth endpoints (per IP — protects against credential stuffing)
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MIN=15

# AI endpoints (per authenticated user — controls LLM cost)
RATE_LIMIT_AI_MAX=20
RATE_LIMIT_AI_WINDOW_MIN=60

# General API (per authenticated user)
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MIN=1
